<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>

    <!-- NuGet package metadata -->
    <PackageId>Ndump.Runtime</PackageId>
    <Version>0.1.0</Version>
    <Authors>ndump contributors</Authors>
    <Description>Runtime support for Ndump generated proxies. Provides the base types and dump-reading infrastructure needed by proxy assemblies generated from .NET memory dumps using ClrMD.</Description>
    <PackageProjectUrl>https://github.com/kevin-montrose/ndump</PackageProjectUrl>
    <RepositoryUrl>https://github.com/kevin-montrose/ndump</RepositoryUrl>
    <RepositoryType>git</RepositoryType>
    <PackageLicenseExpression>MIT</PackageLicenseExpression>
    <PackageTags>dotnet;memory-dump;clrmd;diagnostics;heap;crashdump</PackageTags>

    <!-- Output .nupkg to the nugets folder at the repo root -->
    <PackageOutputPath>$(MSBuildThisFileDirectory)..\..\nugets</PackageOutputPath>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.Diagnostics.Runtime" Version="3.1.512801" />
  </ItemGroup>

</Project>
